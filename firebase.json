{
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "storage": {
    "rules": "firebase/storage.rules"
  },
  "functions": [
    {
      "codebase": "wedding",
      "source": "wedding-invitation/functions",
      "runtime": "nodejs20",
      "ignore": ["node_modules", ".git", "*.local", "lib"]
    },
    {
      "codebase": "koperasi",
      "source": "koperasi/functions",
      "runtime": "nodejs20",
      "ignore": ["node_modules", ".git", "*.local", "lib"]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "functions": { "port": 5001 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true },
    "singleProjectMode": true
  }
}
