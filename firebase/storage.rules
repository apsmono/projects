rules_version = '2';

// One Cloud Storage bucket shared across the workspace. Paths are project-prefixed.
// Admin = the single owner (custom claim `admin == true`, same as Firestore rules).

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isImageUnder(maxBytes) {
      return request.resource.size < maxBytes
             && request.resource.contentType.matches('image/.*');
    }

    // wedding gallery: public read, owner-managed uploads
    match /wedding/{file=**} {
      allow read: if true;
      allow write: if isAdmin() && isImageUnder(10 * 1024 * 1024);
    }

    // generic validated uploads (e.g. koperasi documents): owner-only
    match /uploads/{project}/{file=**} {
      allow read: if isAdmin();
      allow write: if isAdmin() && request.resource.size < 25 * 1024 * 1024;
    }

    // default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
