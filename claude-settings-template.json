{
  "permissions": {
    "allow": [
      "Bash: npm install",
      "Bash: pip install",
      "Bash: uv pip install",
      "Bash: uvicorn",
      "Bash: python -m unittest",
      "Bash: python -m pytest",
      "Bash: git add",
      "Bash: git commit",
      "Bash: git push",
      "Bash: git status",
      "Bash: git log",
      "Bash: git diff",
      "Bash: git submodule",
      "Bash: docker compose",
      "Bash: docker build",
      "Bash: docker run",
      "Bash: bun install",
      "Bash: bun run",
      "Bash: npm run",
      "Bash: npm run build",
      "Bash: npm run dev",
      "Bash: npm run preview",
      "Bash: python -m http.server",
      "Bash: curl",
      "Bash: mkdir",
      "Bash: rm",
      "Bash: mv",
      "Bash: cp",
      "Bash: ls",
      "Bash: cd",
      "Bash: source .venv/bin/activate",
      "Bash: kimi",
      "Bash: n8n",
      "Bash: pnpm",
      "Bash: pnpm install",
      "Bash: pnpm openclaw",
      "Read: .env.example",
      "Read: package.json",
      "Read: requirements.txt",
      "Read: pyproject.toml",
      "Read: docker-compose.yml",
      "Read: Dockerfile",
      "Read: *.md",
      "Read: *.json",
      "Read: *.yaml",
      "Read: *.yml",
      "Read: *.toml",
      "Edit: *.py",
      "Edit: *.js",
      "Edit: *.ts",
      "Edit: *.tsx",
      "Edit: *.jsx",
      "Edit: *.html",
      "Edit: *.css",
      "Edit: *.json",
      "Edit: *.yaml",
      "Edit: *.yml",
      "Edit: *.md",
      "Edit: *.toml",
      "Edit: *.sh",
      "Write: *.py",
      "Write: *.js",
      "Write: *.ts",
      "Write: *.tsx",
      "Write: *.html",
      "Write: *.css",
      "Write: *.json",
      "Write: *.yaml",
      "Write: *.yml",
      "Write: *.md",
      "Write: *.toml",
      "Write: *.sh"
    ],
    "deny": [
      "Bash: rm -rf /",
      "Bash: sudo",
      "Bash: chmod 777",
      "Bash: curl * | bash",
      "Bash: wget * | bash"
    ]
  },
  "hooks": {
    "sessionStart": "echo 'Welcome! Current project: $(basename $(pwd))'",
    "beforeBash": "echo '[Running] $command'"
  },
  "model": {
    "default": "opus",
    "fast": "sonnet"
  }
}
